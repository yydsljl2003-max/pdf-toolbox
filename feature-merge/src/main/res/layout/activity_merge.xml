<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pdf_gray_light"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 返回按钮 -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="返回"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_revert" />

    <!-- 选择文件大按钮 -->
    <Button
        android:id="@+id/btnSelectFiles"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:text="📂 选择PDF文件"
        android:textAllCaps="false"
        android:textColor="@color/pdf_white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 文件列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewFiles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@color/pdf_white"
        android:clipToPadding="false"
        android:padding="8dp" />

    <!-- 文件计数提示 -->
    <TextView
        android:id="@+id/tvFileCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="未选择文件"
        android:textColor="@color/pdf_gray_text"
        android:textSize="16sp" />

    <!-- 合并按钮 -->
    <Button
        android:id="@+id/btnMerge"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/pdf_green"
        android:enabled="false"
        android:text="🔗 合并为1个PDF"
        android:textAllCaps="false"
        android:textColor="@color/pdf_white"
        android:textSize="22sp"
        android:textStyle="bold" />

</LinearLayout>
