        <item name="colorPrimary">@color/pdf_blue</item>
        <item name="colorPrimaryVariant">@color/pdf_blue_dark</item>
        <item name="colorOnPrimary">@color/pdf_white</item>
        <item name="colorSecondary">@color/pdf_green</item>
        <item name="colorSecondaryVariant">@color/pdf_green</item>
        <item name="colorOnSecondary">@color/pdf_white</item>
